                "--dart-define=ENV=dev"
            ]
        },
        {
            "name": "Rightware • Prod",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=ENV=prod"
            ]
        },
        {
            "name": "flutter_technical_task_rightware_llc",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "flutter_technical_task_rightware_llc (profile mode)",
            "request": "launch",
            "type": "dart",
